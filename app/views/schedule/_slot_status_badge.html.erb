<%# Shared status badge for a timeslot, used by both the wide table and the collapsed mobile view. %>
<% if status.signed_up? %>
  <span class="badge bg-primary">You're signed up</span>
<% elsif status.unqualified? %>
  <% status.missing_quals.each do |qual| %>
    <span class="badge bg-secondary qualification-pill"><%= qual.name %> qualification required</span>
  <% end %>
<% elsif status.full? %>
  <span class="badge bg-success">Full</span>
<% elsif status.needs_staff? %>
  <span class="badge bg-danger">Needs Staff</span>
<% else %>
  <span class="badge bg-warning text-dark"><%= slot_data[:signed_up_count] %> of <%= slot_data[:max_volunteers] %></span>
<% end %>
