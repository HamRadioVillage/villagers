<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-primary text-white">
          <h2 class="h4 mb-0">Edit Conference</h2>
        </div>
        <div class="card-body">
          <%= form_with model: @conference, local: true do |form| %>
            <% if @conference.errors.any? %>
              <div class="alert alert-danger">
                <h5 class="alert-heading">Please fix the following errors:</h5>
                <ul class="mb-0">
                  <% @conference.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control", required: true, autofocus: true %>
            </div>

            <%= render "location_fields", form: form %>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :start_date, class: "form-label" %>
                <%= form.date_field :start_date, class: "form-control", required: true %>
              </div>
              <div class="col-md-6 mb-3">
                <%= form.label :end_date, class: "form-label" %>
                <%= form.date_field :end_date, class: "form-control", required: true %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :time_zone, "Time Zone", class: "form-label" %>
              <%= form.time_zone_select :time_zone, ActiveSupport::TimeZone.us_zones, {}, { class: "form-select" } %>
              <div class="form-text">All schedule times, reminders, and calendar exports use this zone.</div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= form.label :conference_hours_start, "Conference Hours Start", class: "form-label" %>
                <%= form.time_field :conference_hours_start, class: "form-control" %>
              </div>
              <div class="col-md-6 mb-3">
                <%= form.label :conference_hours_end, "Conference Hours End", class: "form-label" %>
                <%= form.time_field :conference_hours_end, class: "form-control" %>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :minimum_shift_duration, "Shift Block Size", class: "form-label" %>
              <%= form.select :minimum_shift_duration,
                  options_for_select([ [ "15 minutes", 15 ], [ "30 minutes", 30 ], [ "45 minutes", 45 ], [ "1 hour", 60 ], [ "2 hours", 120 ] ], @conference.minimum_shift_duration),
                  { include_blank: "15 minutes (default)" },
                  { class: "form-select" } %>
              <div class="form-text">
                Volunteers book shifts in whole blocks of this length
                (e.g. 30-minute blocks allow 30, 60, 90&hellip; but not 45).
                Leave blank for the default 15-minute blocks.
              </div>
            </div>

            <div class="mb-3">
              <%= label_tag :conference_lead_id, "Conference Lead", class: "form-label" %>
              <%= select_tag :conference_lead_id,
                  options_from_collection_for_select(@users, :id, :email, @current_lead&.id),
                  { include_blank: "Select a conference lead (optional)", class: "form-select" } %>
              <div class="form-text">The conference lead will have management permissions for this conference.</div>
            </div>

            <hr class="my-4">
            <h5>Notification Settings</h5>

            <div class="mb-3">
              <%= form.label :reminder_hours_before, "Shift Reminder (hours before)", class: "form-label" %>
              <%= form.number_field :reminder_hours_before, class: "form-control", min: 1, max: 168 %>
              <div class="form-text">
                Send volunteers a reminder email this many hours before their shift starts.
                Leave blank to use the village default (<%= @conference.village.reminder_hours_before || 24 %> hours).
              </div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
              <%= link_to "Cancel", @conference, class: "btn btn-secondary btn-lg" %>
              <%= form.submit "Update Conference", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
