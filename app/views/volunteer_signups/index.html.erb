<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
          <%= link_to @conference, class: "btn btn-secondary btn-sm me-3" do %>
            <span aria-hidden="true">&larr;</span> Conference
          <% end %>
          <h1 class="mb-0">My Shifts - <%= @conference.name %></h1>
        </div>
        <%= link_to "View Schedule", conference_schedule_path(@conference), class: "btn btn-primary" %>
      </div>
    </div>
  </div>

  <% if @shift_groups.any? %>
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header bg-success text-white">
            <h5 class="mb-0">Your Signed Up Shifts (<%= @my_signups.count %> timeslots in <%= @shift_groups.count %> shift<%= 's' if @shift_groups.count != 1 %>)</h5>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-striped mb-0">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Program</th>
                    <th>Duration</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @shift_groups.each do |group| %>
                    <%
                      duration_minutes = ((group[:end_time] - group[:start_time]) / 60).to_i
                      hours = duration_minutes / 60
                      minutes = duration_minutes % 60
                      duration_str = hours > 0 ? "#{hours} hr" : ""
                      duration_str += " #{minutes} min" if minutes > 0
                    %>
                    <tr>
                      <td><%= group[:start_time].strftime("%A, %B %d") %></td>
                      <td>
                        <%= group[:start_time].strftime("%l:%M %p").strip %> -
                        <%= group[:end_time].strftime("%l:%M %p").strip %>
                      </td>
                      <td><%= group[:program_name] %></td>
                      <td><%= duration_str.strip %></td>
                      <td>
                        <%= link_to "Cancel",
                            bulk_destroy_conference_volunteer_signups_path(@conference, signup_ids: group[:signups].map(&:id)),
                            data: {
                              turbo_method: :delete,
                              turbo_confirm: "Are you sure you want to cancel this #{duration_str.strip} shift?"
                            },
                            class: "btn btn-sm btn-outline-danger" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="row">
      <div class="col-12">
        <div class="alert alert-info">
          <h5>No Shifts Yet</h5>
          <p class="mb-0">You haven't signed up for any shifts yet. <%= link_to "View the schedule", conference_schedule_path(@conference) %> to find available timeslots.</p>
        </div>
      </div>
    </div>
  <% end %>
</div>
