<% if DemoMode.enabled? %>
  <div class="demo-banner alert alert-warning text-center mb-0 rounded-0 py-2" role="alert">
    <strong><%= DemoMode.banner_text %></strong>
    <% if (time_remaining = DemoMode.formatted_time_until_reset) %>
      <span class="ms-2 text-muted small">(Resets in <%= time_remaining %>)</span>
    <% end %>
  </div>
<% end %>
